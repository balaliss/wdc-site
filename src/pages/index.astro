---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import {
  site,
  services,
  caseStudies,
  howIWork,
  consultingOffer,
  idealClient,
  aiDifferentiator,
} from '../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      name: site.name,
      url: site.url,
      email: site.email,
      areaServed: 'United States',
      serviceType: 'AI consulting, tech implementation, and program management for healthtech',
      description: consultingOffer.summary,
      founder: {
        '@type': 'Person',
        name: site.founderName,
        url: site.founderUrl,
      },
    },
  ],
};
---

<BaseLayout
  path="/"
  description="Fractional AI consulting, integration ops, and technical program management for healthtech teams — remote US."
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container">
      <p class="section-label">AI & Tech Consulting · Healthtech · Remote US</p>
      <h1>{consultingOffer.headline}</h1>
      <p class="tagline">{site.tagline}</p>
      <p class="hero-lead">
        Wissahickon Data Collective helps healthtech teams implement AI, stabilize integrations,
        and manage complex tech programs — without hiring full-time. Every engagement is
        AI-delivered: multi-agent strategy reviews, sharper requirements, and faster turnaround
        than a traditional firm.
      </p>
      <div class="offer-meta">
        <span class="offer-pill">{consultingOffer.priceRange}</span>
        <span class="offer-pill">{consultingOffer.pilot}</span>
        <span class="offer-pill">{consultingOffer.schedule}</span>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href={site.discoveryMailto}>Book a 20-min discovery call</a>
        <a class="btn btn-secondary" href="/services">See all services</a>
        <a class="btn btn-secondary" href="#proof">See proof</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <p class="section-label">The problem</p>
      <h2>When AI and tech debt outrun headcount</h2>
      <div class="problem-grid">
        <div class="step">
          <h3>AI with no roadmap</h3>
          <p>Leadership wants AI. Nobody owns what to build first, what to buy, or how to measure it.</p>
        </div>
        <div class="step">
          <h3>Integration firefighting</h3>
          <p>Production issues and partner escalations eat the week. No intake standards, no reliability targets.</p>
        </div>
        <div class="step">
          <h3>Initiatives with no owner</h3>
          <p>A platform migration, compliance project, or AI rollout has budget and sign-off — but no TPM to drive it.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Services</p>
      <h2>Three ways to engage</h2>
      <div class="services-grid">
        {services.map((svc) => (
          <div class="service-card">
            <h3>{svc.name}</h3>
            <p class="service-tagline">{svc.tagline}</p>
            <p>{svc.summary}</p>
            <div class="service-meta">
              <span class="offer-pill">{svc.priceRange}</span>
              <span class="offer-pill">{svc.engagement}</span>
            </div>
            <p class="service-best-for"><strong>Best for:</strong> {svc.bestFor}</p>
          </div>
        ))}
      </div>
      <p style="margin-top: 2rem; margin-bottom: 0">
        <a href="/services">Full scope, boundaries, and pricing for each →</a>
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <p class="section-label">{aiDifferentiator.headline}</p>
      <h2>AI is the delivery model, not the buzzword</h2>
      <p>{aiDifferentiator.body}</p>
      <ul class="check-list" style="margin-top: 1.5rem">
        {aiDifferentiator.points.map((pt) => <li>{pt}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Who we work with</p>
      <h2>Ideal client profile</h2>
      <ul class="check-list">
        {idealClient.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section section-alt" id="proof">
    <div class="container">
      <p class="section-label">Proof</p>
      <h2>Case studies</h2>
      <div class="card-grid">
        {caseStudies.map((cs) => <CaseStudyCard {...cs} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Operating philosophy</p>
      <h2>How we work</h2>
      <div class="steps">
        {howIWork.map((step) => (
          <div class="step">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <p class="section-label">Leadership</p>
      <h2>Led by {site.founderName}</h2>
      <p>
        {site.founderName} owned delivery for 20+ AI and data integration programs at Transcarent —
        SLO/SLA governance, observability dashboards, AI enablement workshops, and a P0 data
        warehouse migration. Led a 14-person platform team at Persevere Now. Certified: PSPO I,
        AWS Cloud Practitioner, Salesforce AI Associate, AWS AI Practitioner (in progress).
        M.S. AI &amp; Machine Learning, Eastern University (resuming 2026).
      </p>
      <p style="margin-bottom: 0">
        Personal portfolio: <a href={site.founderUrl} rel="noopener">{site.founderUrl.replace('https://', '')}</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-panel">
        <h2>{consultingOffer.capacity}</h2>
        <p>
          Async-first. {consultingOffer.pilot}. Book a 20-minute call to see if there's a fit.
        </p>
        <a class="btn btn-primary" href={site.discoveryMailto}>Book a 20-min discovery call</a>
      </div>
    </div>
  </section>
</BaseLayout>
